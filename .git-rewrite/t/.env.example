# QA Automation Backend Configuration
# Copy this file to .env and update values for your environment

# ────── Database Configuration ──────
DATABASE_URL=postgresql+asyncpg://qa_user:qa_password@localhost:5432/qa_automation

# ────── Redis Configuration ──────
REDIS_URL=redis://localhost:6379

# ────── JWT Configuration ──────
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ────── CORS Configuration ──────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ────── Application Configuration ──────
APP_NAME=QA Automation Backend
APP_VERSION=1.0.0
DEBUG=false

# ────── Logging Configuration ──────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ────── Email Configuration (Optional) ──────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@qa-automation.com

# ────── AWS Configuration (Optional) ──────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=qa-automation-reports

# ────── Celery Configuration ──────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_TIMEOUT=3600
CELERY_TASK_MAX_RETRIES=3

# ────── Sentry Configuration (Error Tracking) ──────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ────── Claude AI Configuration ──────
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4096

# ────── Feature Flags ──────
ENABLE_ANALYTICS=true
ENABLE_AI_FEATURES=true
ENABLE_WEBHOOKS=true

# ────── Rate Limiting ──────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_SECOND=10

# ────── Test Configuration ──────
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:
TEST_MODE=false
