{
  "name": "zero-to-test-ai",
  "version": "1.0.0",
  "description": "AI-powered QA pipeline — 7 agents from GitHub issue to executed, self-healing Playwright test suite",
  "private": true,
  "scripts": {
    "test": "playwright test && python3 scripts/generate_html_report.py test-results/results.json --output qa-report.html 2>/dev/null; open qa-report.html",
    "test:smoke": "playwright test --grep @smoke",
    "test:orangehrm": "playwright test tests/e2e/orangehrm-autonomous-discovery.spec.ts tests/e2e/orangehrm-comprehensive.spec.ts tests/e2e/orangehrm-mandatory-elements.spec.ts",
    "test:orangehrm:smoke": "playwright test tests/e2e/orangehrm-autonomous-discovery.spec.ts --grep @smoke",
    "test:demoqa": "playwright test tests/e2e/demoqa.spec.ts tests/e2e/demoqa-adaptive.spec.ts",
    "test:demoqa:smoke": "playwright test tests/e2e/demoqa.spec.ts --grep @smoke",
    "test:shop": "playwright test tests/e2e/demowebshop.spec.ts tests/e2e/demowebshop-test-suite.spec.ts",
    "test:shop:smoke": "playwright test tests/e2e/demowebshop.spec.ts --grep @smoke",
    "test:unit": "python -m pytest tests/unit/ -v",
    "report": "python3 scripts/generate_html_report.py test-results/results.json --output qa-report.html 2>/dev/null; open qa-report.html",
    "council": "python3 council.py",
    "council:demo": "python3 council.py --demo",
    "pipeline:demo": "python -m orchestrator.pipeline --demo --offline"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "allure-playwright": "^3.10.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "vibium": "^26.5.31"
  }
}
